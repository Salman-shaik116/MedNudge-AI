# Local environment variables (DO NOT commit your real .env)
# Copy this file to .env and fill in values.

# Django
DEBUG=True
SECRET_KEY=change-me-to-a-long-random-string
ALLOWED_HOSTS=127.0.0.1,localhost

# Database (Option A: MySQL via DB_*)
# If you use MySQL locally, set these.
DB_ENGINE=django.db.backends.mysql
DB_NAME=signup_db
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_HOST=127.0.0.1
DB_PORT=3306

# Database (Option B: single DATABASE_URL)
# If you prefer a single URL (Postgres/MySQL/etc), set this and remove/ignore DB_*.
# Example (Postgres):
# DATABASE_URL=postgres://user:password@host:5432/dbname
# Example (MySQL):
# DATABASE_URL=mysql://user:password@127.0.0.1:3306/signup_db

# AI Provider: groq or xai
AI_PROVIDER=groq

# Groq
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.1-70b-versatile

# xAI (Grok) - OpenAI-compatible endpoint
XAI_API_KEY=your_xai_api_key
XAI_MODEL=grok-2-latest
XAI_BASE_URL=https://api.x.ai/v1

# OCR (optional; helps on Windows if auto-detection fails)
# TESSERACT_CMD=C:\\Program Files\\Tesseract-OCR\\tesseract.exe
